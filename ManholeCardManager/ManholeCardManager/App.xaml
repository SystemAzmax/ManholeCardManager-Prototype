<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ManholeCardManager.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ManholeCardManager"
    xmlns:converters="using:ManholeCardManager.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources
                    xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- コンバーター登録 -->
            <converters:AcquisitionStatusColorConverter
                x:Key="AcquisitionStatusColorConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
