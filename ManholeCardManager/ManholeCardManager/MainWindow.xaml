<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ManholeCardManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ManholeCardManager"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource
 ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <Grid Grid.Row="0" Padding="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="AppTitleBlock"
                       Style="{StaticResource TitleTextBlockStyle}"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        Spacing="10">
                <TextBlock x:Name="LanguageLabelBlock"
                           VerticalAlignment="Center"
                           Style="{StaticResource
                           BodyStrongTextBlockStyle}"/>
                <ComboBox x:Name="LanguageComboBox" Width="150"
                          ItemsSource="{Binding
                          LocalizationService.SupportedLanguages}"
                          SelectedValuePath="LanguageCode"
                          SelectionChanged="LanguageComboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LanguageName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- メインコンテンツ -->
        <Grid Grid.Row="1" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 検索 -->
            <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,15">
                <TextBlock x:Name="DistributionLocationsLabel"
                           Text="配布場所一覧"
                           Style="{StaticResource
                           SubtitleTextBlockStyle}"/>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="LocationSearchBox" Height="40"
                             PlaceholderText="場所名で検索..."
                             Text="{Binding
                             DistributionLocationViewModel.SearchText,
                             Mode=TwoWay,
                             UpdateSourceTrigger=PropertyChanged}"/>
                    <ComboBox Grid.Column="1" x:Name="SeriesNumberFilterComboBox" 
                              Height="40"
                              ItemsSource="{Binding
                              DistributionLocationViewModel.SeriesNumbers}"
                              SelectedItem="{Binding
                              DistributionLocationViewModel.SelectedSeriesNumber,
                              Mode=TwoWay}"
                              SelectionChanged="SeriesNumberFilterComboBox_SelectionChanged"
                              DropDownOpened="SeriesNumberFilterComboBox_DropDownOpened">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </StackPanel>

            <!-- カード一覧 -->
            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding
                              DistributionLocationViewModel.Locations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="15" Margin="0,0,0,20">
                                <!-- 配布場所ヘッダー -->
                                <StackPanel Spacing="5">
                                    <TextBlock Text="{Binding
                                               LocationName}"
                                               FontSize="20"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Address}"
                                               FontSize="12"/>
                                </StackPanel>

                                <!-- 配布場所のカード一覧 -->
                                <ItemsControl ItemsSource="{Binding
                                              DistributedCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="10"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12"
                                                    Padding="20"
                                                    Background="{ThemeResource
                                                    CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource
                                                    CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1">
                                                <Grid ColumnSpacing="15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition
                                                            Width="120"/>
                                                        <ColumnDefinition
                                                            Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 左側：カードデザイン画像風 -->
                                                    <StackPanel
                                                        Grid.Column="0"
                                                        Spacing="8">
                                                        <Border
                                                            CornerRadius="8"
                                                            Background="#E8F5E9"
                                                            Height="140"
                                                            BorderBrush="#4CAF50"
                                                            BorderThickness="3">
                                                            <Grid>
                                                                <!-- カードデザイン画像 -->
                                                                <Image
                                                                    Source="{Binding CachedImagePath}"
                                                                    Stretch="Uniform"/>
                                                                
                                                                <!-- 取得ステータス表示（画像の上に重ねる） -->
                                                                <Button
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    Padding="8"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Top"
                                                                    Click="AcquisitionStatus_Click">
                                                                    <Grid>
                                                                        <Ellipse
                                                                            Width="32"
                                                                            Height="32"
                                                                            Fill="{Binding
                                                                            IsAcquired,
                                                                            Converter={StaticResource
                                                                            AcquisitionStatusColorConverter}}"/>
                                                                        <TextBlock
                                                                            Text="{Binding
                                                                            AcquisitionStatusDisplay}"
                                                                            FontSize="20"
                                                                            FontWeight="Bold"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="White"/>
                                                                    </Grid>
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock
                                                            Text="{Binding
                                                            LocationDisplay}"
                                                            FontSize="11"
                                                            TextAlignment="Center"
                                                            TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <!-- 右側：カード情報 -->
                                                    <StackPanel
                                                        Grid.Column="1"
                                                        Spacing="8">
                                                        <!-- 詳細情報グリッド -->
                                                        <Grid
                                                            ColumnSpacing="15"
                                                            RowSpacing="8"
                                                            Margin="0,0,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition
                                                                    Width="*"/>
                                                                <ColumnDefinition
                                                                    Width="*"/>
                                                                <ColumnDefinition
                                                                    Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition
                                                                    Height="Auto"/>
                                                                <RowDefinition
                                                                    Height="Auto"/>
                                                                <RowDefinition
                                                                    Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Row 0: 発行日 -->
                                                            <StackPanel
                                                                Grid.Row="0"
                                                                Grid.Column="0"
                                                                Spacing="2">
                                                                <TextBlock
                                                                    Text="発行日"
                                                                    FontSize="11"
                                                                    FontWeight="Bold"/>
                                                                <TextBlock
                                                                    Text="{Binding
                                                                    IssuedDateDisplay}"
                                                                    FontSize="13"/>
                                                            </StackPanel>

                                                            <!-- Row 0: 保存ボタン -->
                                                            <Button
                                                                Grid.Row="0"
                                                                Grid.Column="2"
                                                                Height="40"
                                                                Click="SaveAcquisitionData_Click"
                                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                                FontSize="12"
                                                                Padding="12,4"
                                                                Background="Transparent">
                                                                <!-- 保存ボタンコンテンツ -->
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <!-- テキスト（常時表示） -->
                                                                    <TextBlock
                                                                        Text="💾 保存"
                                                                        VerticalAlignment="Center"/>
                                                                    <!-- インジケータエリア（固定幅） -->
                                                                    <Grid Width="16" Height="16">
                                                                        <!-- 未保存：黒丸 -->
                                                                        <TextBlock
                                                                            Text="●"
                                                                            Foreground="Gray"
                                                                            FontSize="12"
                                                                            VerticalAlignment="Center"
                                                                            HorizontalAlignment="Center"
                                                                            Visibility="{Binding SaveStatus, Converter={StaticResource SaveStatusToVisibilityConverter}, ConverterParameter=unsaved}"/>
                                                                        <!-- 保存中：スピナー -->
                                                                        <ProgressRing
                                                                            IsActive="True"
                                                                            Width="16"
                                                                            Height="16"
                                                                            Visibility="{Binding SaveStatus, Converter={StaticResource SaveStatusToVisibilityConverter}, ConverterParameter=saving}"/>
                                                                        <!-- 保存成功：チェック -->
                                                                        <TextBlock
                                                                            Text="✓"
                                                                            Foreground="Green"
                                                                            FontSize="16"
                                                                            FontWeight="Bold"
                                                                            VerticalAlignment="Center"
                                                                            HorizontalAlignment="Center"
                                                                            Visibility="{Binding SaveStatus, Converter={StaticResource SaveStatusToVisibilityConverter}, ConverterParameter=success}"/>
                                                                        <!-- 保存失敗：バツ -->
                                                                        <TextBlock
                                                                            Text="✕"
                                                                            Foreground="Red"
                                                                            FontSize="16"
                                                                            FontWeight="Bold"
                                                                            VerticalAlignment="Center"
                                                                            HorizontalAlignment="Center"
                                                                            Visibility="{Binding SaveStatus, Converter={StaticResource SaveStatusToVisibilityConverter}, ConverterParameter=error}"/>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Button>

                                                            <!-- Row 1: 弾数 -->
                                                            <StackPanel
                                                                Grid.Row="1"
                                                                Grid.Column="0"
                                                                Spacing="2">
                                                                <TextBlock
                                                                    Text="弾数"
                                                                    FontSize="11"
                                                                    FontWeight="Bold"/>
                                                            </StackPanel>

                                                            <!-- Row 1: 概要 -->
                                                            <StackPanel
                                                                Grid.Row="1"
                                                                Grid.Column="1"
                                                                Spacing="2">
                                                                <TextBlock
                                                                    Text="概要"
                                                                    FontSize="11"
                                                                    FontWeight="Bold"/>
                                                                <TextBlock
                                                                    Text="{Binding
                                                                    DescriptionDisplay}"
                                                                    FontSize="13"
                                                                    TextWrapping="Wrap"/>
                                                            </StackPanel>

                                                            <!-- Row 1: 取得日時 -->
                                                            <StackPanel
                                                                Grid.Row="1"
                                                                Grid.Column="2"
                                                                Spacing="2">
                                                                <TextBlock
                                                                    Text="取得日時"
                                                                    FontSize="11"
                                                                    FontWeight="Bold"/>
                                                                <Grid ColumnSpacing="5">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBox
                                                                        Grid.Column="0"
                                                                        x:Name="AcquisitionDateTextBox"
                                                                        Height="32"
                                                                        Text="{Binding AcquisitionDateDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                        PlaceholderText="ISO 8601 形式"
                                                                        TextChanged="AcquisitionDateTextBox_TextChanged"/>
                                                                    <Button
                                                                        Grid.Column="1"
                                                                        Content="📅"
                                                                        Width="40"
                                                                        Height="32"
                                                                        Click="AcquisitionDatePicker_Click"/>
                                                                </Grid>
                                                            </StackPanel>

                                                            <!-- Row 2: 都道府県 -->
                                                            <StackPanel
                                                                Grid.Row="2"
                                                                Grid.Column="0"
                                                                Spacing="2">
                                                                <TextBlock
                                                                    Text="都道府県"
                                                                    FontSize="11"
                                                                    FontWeight="Bold"/>
                                                                <TextBlock
                                                                    Text="{Binding
                                                                    Prefecture}"
                                                                    FontSize="11"
                                                                    TextWrapping="Wrap"/>
                                                            </StackPanel>

                                                            <!-- Row 2: 在庫状況 -->
                                                            <StackPanel
                                                                Grid.Row="2"
                                                                Grid.Column="1"
                                                                Spacing="2">
                                                                <TextBlock
                                                                    Text="在庫状況"
                                                                    FontSize="11"
                                                                    FontWeight="Bold"/>
                                                                <StackPanel
                                                                    Orientation="Horizontal"
                                                                    Spacing="5">
                                                                    <Button
                                                                        Content="{Binding
                                                                        StockStatus}"
                                                                        Tag="{Binding
                                                                        StockStatus}"
                                                                        Click="StockStatusLink_Click"
                                                                        Style="{StaticResource
                                                                        TextBlockButtonStyle}"
                                                                        FontSize="13"
                                                                        Padding="0"
                                                                        MinWidth="0"
                                                                        MinHeight="0"
                                                                        Foreground="{ThemeResource
                                                                        AccentTextFillColorPrimaryBrush}"
                                                                        Visibility="{Binding
                                                                        StockStatus,
                                                                        Converter={StaticResource
                                                                        IsUrlConverter}}"/>
                                                                    <TextBlock
                                                                        Text="{Binding
                                                                        StockStatus}"
                                                                        FontSize="13"
                                                                        Visibility="{Binding
                                                                        StockStatus,
                                                                        Converter={StaticResource
                                                                        IsUrlConverter},
                                                                        ConverterParameter=false}"/>
                                                                    <TextBlock
                                                                        Text="{Binding
                                                                        StockCountDisplay}"
                                                                        FontSize="13"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <!-- Row 2: 備考 -->
                                                            <StackPanel
                                                                Grid.Row="2"
                                                                Grid.Column="2"
                                                                Spacing="2">
                                                                <TextBlock
                                                                    Text="備考"
                                                                    FontSize="11"
                                                                    FontWeight="Bold"/>
                                                                <TextBox
                                                                    x:Name="NotesTextBox"
                                                                    Height="80"
                                                                    AcceptsReturn="True"
                                                                    TextWrapping="Wrap"
                                                                    PlaceholderText="備考を入力してください（3行程度）"
                                                                    Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    TextChanged="NotesTextBox_TextChanged"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Height="1"
                                        Background="{ThemeResource
                                        DividerStrokeColorDefaultBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <TeachingTip x:Name="LoadingTip"
                     IsOpen="{Binding IsLoading}"
                     IsLightDismissEnabled="False"/>
    </Grid>
</Window>
